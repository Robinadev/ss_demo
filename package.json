{
  "name": "safehaven-platform",
  "version": "1.0.0",
  "description": "SafeHaven - Violence, Abuse, and Bullying Digital Reporting Platform",
  "private": true,
  "scripts": {
    "dev:backend": "cd complete/SafeHave-complete-backend/backend && npm run start:dev",
    "dev:frontend": "cd complete/SafeHave-complete-backend/frontend && npm run dev",
    "dev": "npm run dev:backend &",
    "build": "cd complete/SafeHave-complete-backend/backend && npm run build && cd ../frontend && npm run build",
    "start": "cd complete/SafeHave-complete-backend/backend && npm run start:prod",
    "test": "cd complete/SafeHave-complete-backend/backend && npm run test",
    "lint": "cd complete/SafeHave-complete-backend/backend && npm run lint",
    "format": "cd complete/SafeHave-complete-backend/backend && npm run format",
    "db:setup": "cd complete/SafeHave-complete-backend/backend && npm run db:setup",
    "db:reset": "cd complete/SafeHave-complete-backend/backend && npm run db:reset",
    "db:seed": "cd complete/SafeHave-complete-backend/backend && npm run prisma:seed",
    "install:all": "npm install && cd complete/SafeHave-complete-backend/backend && npm install && cd ../frontend && npm install",
    "setup": "npm run install:all && npm run db:setup",
    "clean": "rimraf node_modules complete/SafeHave-complete-backend/backend/node_modules complete/SafeHave-complete-backend/frontend/node_modules complete/SafeHave-complete-backend/backend/dist complete/SafeHave-complete-backend/frontend/dist"
  },
  "devDependencies": {
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.0"
  }
}
