        PHYSICAL_VIOLENCE: 1,
        CYBERBULLYING: 1,
        CHILD_ABUSE: 1,
        EMOTIONAL_ABUSE: 1,
      }),
      reportsBySeverity: JSON.stringify({
        LOW: 0,
        MEDIUM: 2,
        HIGH: 1,
        CRITICAL: 1,
      }),
