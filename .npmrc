# npm configuration to prevent browser opening and other issues

# Disable opening browser on npm commands
browser=none

# Prevent postinstall scripts from running by default
ignore-scripts=false

# Use exact versions
save-exact=false

# Increase timeout for large packages
fetch-timeout=120000

# Use legacy peer deps to avoid conflicts
legacy-peer-deps=true

# Set registry
registry=https://registry.npmjs.org/

# Disable update notifier
update-notifier=false

# Disable any script that tries to open browser
progress=false

# Disable audit
audit=false
